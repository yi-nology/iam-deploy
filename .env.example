SERVER_ADDRESS=0.0.0.0
SERVER_PORT=8000
SERVER_RPC_PORT=9000

DB_DRIVER=mysql
DB_DSN=root:root@tcp(mysql:3306)/iam?charset=utf8mb4&parseTime=True&loc=Local
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=10

REDIS_ENDPOINT=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

JWT_SECRET=your-super-secret-key-change-in-production-at-least-32-chars
JWT_EXPIRATION=2h
JWT_REFRESH_EXPIRE=168h
JWT_ISSUER=iam-server

CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80

RATE_LIMIT=100
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=15m

TRUSTED_HOSTS=localhost,127.0.0.1
INIT_TOKEN=

LOG_LEVEL=info
LOG_FORMAT=json

# ==================== 构建配置 ====================
# GitCode 访问令牌：用于克隆仓库并使 iam-server 构建时 go mod download
# 能拉取私有依赖(gitcode.com/yi-nology/iam-sdk)。必填。
GITCODE_TOKEN=
# GHCR 镜像归属(owner)，构建出的镜像 tag 前缀
GHCR_OWNER=yi-nology
